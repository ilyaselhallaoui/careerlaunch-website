---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Products — CareerLaunch"
  description="Resources for CS students who want to get hired."
  path="/products"
  currentPath="/products"
>
  <section class="hero narrow">
    <p class="eyebrow">Products</p>
    <h1>Tools and resources for getting hired.</h1>
    <p class="lede">
      Start with DevScore. More CareerLaunch products are coming after the free challenge and first guides are live.
    </p>
    <div class="button-row">
      <a class="button" href="/devscore">Get your DevScore</a>
      <a class="button secondary" href="https://www.skool.com/careerlaunch-challenge-6591/about" target="_blank" rel="noopener noreferrer">Join the waitlist</a>
    </div>
  </section>
</BaseLayout>
