---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Products — CareerLaunch"
  description="Ressourcen für Informatik-Studenten, die wirklich eingestellt werden wollen. Demnächst verfügbar."
  path="/products"
  currentPath="/products"
>
  <section class="hero narrow">
    <p class="eyebrow">Products</p>
    <h1>Coming soon.</h1>
    <p class="lede">
      Resources for CS students who want to get hired. Join the waitlist on Skool to get notified first.
    </p>
    <div class="button-row">
      <a class="button" href="https://www.skool.com/careerlaunch-challenge-6591/about" target="_blank" rel="noopener noreferrer">Join the waitlist</a>
    </div>
  </section>
</BaseLayout>
