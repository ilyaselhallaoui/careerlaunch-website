---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Products — CareerLaunch"
  description="Guides, tools, and resources for CS students who want to get hired. Coming soon."
  path="/products"
  currentPath="/products"
>
  <section class="hero narrow">
    <p class="eyebrow">Products</p>
    <h1>Coming soon.</h1>
    <p class="lede">
      eBooks, tools, and career resources for CS students who want to stop guessing and start building.
    </p>
  </section>

  <section class="section">
    <div class="coming-soon">
      <p class="eyebrow">In the pipeline</p>
      <p>Three eBooks are almost done. A career analyzer tool (submit your LinkedIn, GitHub, resume, and a job posting, get back a detailed breakdown of why you're not getting interviews and exactly what to fix) is in development. Join the waitlist on Skool to get early access.</p>
      <div class="button-row">
        <a class="button" href="https://www.skool.com/careerlaunch-challenge-6591/about" target="_blank" rel="noopener noreferrer">Join the waitlist — coming soon</a>
      </div>
    </div>
  </section>
</BaseLayout>
